# ─────────────────────────────────────────────────────────────
#  SSO SAML — SimpleSAMLphp (sso.solcera.sol)
#  À copier dans backend/.env sur la VM, puis : pm2 restart indus-web
# ─────────────────────────────────────────────────────────────

# URL publique de l'app (pour les redirections après login)
APP_URL=https://indus.solcera.sol

# entityID de NOTRE application (le SP). Doit correspondre EXACTEMENT
# à ce qui est déclaré côté SimpleSAMLphp (saml20-sp-remote.php).
SAML_ISSUER=https://indus.solcera.sol/api/auth/saml/metadata

# Notre ACS (où l'IdP renvoie l'assertion)
SAML_CALLBACK_URL=https://indus.solcera.sol/api/auth/saml/acs

# ── Côté IdP SimpleSAMLphp ──
# URL SSO de l'IdP. Conventions SimpleSAMLphp (À VÉRIFIER sur la page
# "Federation" → métadonnées IdP de votre instance) :
SAML_ENTRY_POINT=https://sso.solcera.sol/simplesaml/saml2/idp/SSOService.php
SAML_LOGOUT_URL=https://sso.solcera.sol/simplesaml/saml2/idp/SingleLogoutService.php

# Certificat de signature de l'IdP.
# Par défaut le backend lit backend/saml/idp.crt (déjà déposé via le dépôt).
# Pour pointer un autre fichier : SAML_CERT_FILE=/chemin/vers/idp.crt
# (ou coller le PEM inline dans SAML_CERT avec des \n échappés)
# SAML_CERT_FILE=

# ── Mapping des attributs SAML ──
# IMPORTANT : le NameID de SimpleSAMLphp est "transient" (change à chaque
# session) → il FAUT un attribut stable pour identifier l'utilisateur.
# Mettez ici le nom de l'attribut identifiant libéré par l'IdP.
# Valeurs fréquentes : uid, sAMAccountName, mail, eduPersonPrincipalName.
# Vérifiez via SimpleSAMLphp → "Test des sources d'authentification".
SAML_ATTR_LOGIN=uid
SAML_ATTR_NOM=displayName
SAML_ATTR_MAIL=mail
