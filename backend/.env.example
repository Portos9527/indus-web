# ── Base de données ──
DATABASE_URL=postgresql://indus_app:motdepasse@srv-indus.solcera.local:5432/indus_db

# ── Sécurité / serveur ──
JWT_SECRET=remplacez-par-une-longue-chaine-aleatoire-secrete
PORT=3001
CORS_ORIGIN=http://localhost:5173

# URL publique du frontend (pour les redirections SSO). Ex : https://indus.solcera.local
APP_URL=

# ── Compte admin initial (créé/complété au 1er démarrage) ──
ADMIN_LOGIN=admin
ADMIN_PASSWORD=changez-moi
ADMIN_NOM=Administrateur

# ── Pièces jointes (stockage sur la VM) ──
# Dossier où sont enregistrés les fichiers. Défaut : backend/uploads
UPLOAD_DIR=

# ── SSO SAML (portail SOLCERA / IT Help) ──
# Laisser vide pour désactiver le bouton "Connexion Automatique".
# Renseigner avec les infos fournies par l'IT (métadonnées de l'IdP) :
SAML_ENTRY_POINT=        # URL SSO de l'IdP (ex : https://sso.solcera.com/adfs/ls/)
SAML_ISSUER=indus-web    # entityID de notre application (SP)
SAML_CALLBACK_URL=       # notre ACS, ex : https://indus.solcera.local/api/auth/saml/acs
SAML_CERT=               # certificat X509 de signature de l'IdP (une seule ligne, \n entre les lignes)
SAML_LOGOUT_URL=         # optionnel
# Attribut SAML contenant l'identifiant (sinon le NameID est utilisé) :
SAML_ATTR_LOGIN=         # ex : sAMAccountName  ou  http://schemas.../name
SAML_ATTR_NOM=displayName
SAML_ATTR_MAIL=email
